{
    "name": "becklyn/ddd-symfony-security",
    "description": "Security component used in legacy 201Created projects",
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Marko Vujnovic",
            "email": "mv@becklyn.com"
        },
        {
            "name": "Marco Woehr",
            "email": "mw@becklyn.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "becklyn/ddd-core": "^4.0",
        "becklyn/ddd-doctrine-bridge": "^3.0",
        "becklyn/ddd-symfony-bridge": "^6.0",
        "becklyn/utilities": "^3.0",
        "doctrine/doctrine-bundle": "^2.0",
        "doctrine/orm": "^2.12 || ^3.0",
        "stof/doctrine-extensions-bundle": "^1.4",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/http-foundation": "^6.4 || ^7.0",
        "symfony/mailer": "^6.4 || ^7.0",
        "symfony/notifier": "^6.4 || ^7.0",
        "symfony/security-bundle": "^6.4 || ^7.0",
        "symfony/twig-pack": "^1.0",
        "twig/cssinliner-extra": "^3.0",
        "twig/inky-extra": "^3.0"
    },
    "require-dev": {
        "phpspec/prophecy-phpunit": "^2.0",
        "phpunit/phpunit": "^9.1"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Becklyn\\Security\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Becklyn\\Security\\Tests\\": "tests/"
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": true
        }
    }
}
